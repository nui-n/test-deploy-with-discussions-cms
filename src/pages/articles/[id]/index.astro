import { render } from 'astro:content';

// Query
import { getAvailableArticles } from '../../../query/articles.query';

// Layouts
import Page from '../../../layouts/Page.astro';

export async function getStaticPaths() {
  const articles = await getAvailableArticles();

  return Promise.all(
    articles.map(async (article) => ({
      params: { id: article.id },
      props: { article },
    })),
  );
}

const { article } = Astro.props;

const { Content } = await render(article);

function format(date: Date): string {
  return date.toISOString().replace('.000', '');
}

const publishedAt = format(article.data.created_at);
const updatedAt = format(article.data.updated_at);
---

<Page title={article.data.title} description={article.data.description || 'このページの説明はありません'}>
  <h1>{article.data.title}</h1>
  <dl>
    <dt>公開日</dt>
    <dd><time datetime={publishedAt}>{publishedAt}</time></dd>
    <dt>更新日</dt>
    <dd><time datetime={updatedAt}>{updatedAt}</time></dd>
  </dl>

  <Content />
</Page>
